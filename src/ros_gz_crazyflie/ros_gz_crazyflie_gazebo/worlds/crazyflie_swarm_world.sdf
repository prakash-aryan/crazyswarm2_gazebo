          <rotor><jointName>cf4/m1_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>1</direction></rotor>
          <rotor><jointName>cf4/m2_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>-1</direction></rotor>
          <rotor><jointName>cf4/m3_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>1</direction></rotor>
          <rotor><jointName>cf4/m4_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>-1</direction></rotor>
        </rotorConfiguration>
      </plugin>
      <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
        <dimensions>3</dimensions>
      </plugin>
    </model>

    <!-- Walls enclosing the arena -->
    <model name="wall1">
      <pose>3 0 0.5 0 0 0</pose>
      <static>true</static>
      <link name="link"><visual name="visual"><geometry><box><size>0.2 6 1</size></box></geometry></visual></link>
    </model>
    <model name="wall2">
      <pose>-3 0 0.5 0 0 0</pose>
      <static>true</static>
      <link name="link"><visual name="visual"><geometry><box><size>0.2 6 1</size></box></geometry></visual></link>
    </model>
    <model name="wall3">
      <pose>0 3 0.5 0 0 1.57</pose>
      <static>true</static>
      <link name="link"><visual name="visual"><geometry><box><size>0.2 6 1</size></box></geometry></visual></link>
    </model>
    <model name="wall4">
      <pose>0 -3 0.5 0 0 1.57</pose>
      <static>true</static>
      <link name="link"><visual name="visual"><geometry><box><size>0.2 6 1</size></box></geometry></visual></link>
    </model>
  </world>
</sdf>
