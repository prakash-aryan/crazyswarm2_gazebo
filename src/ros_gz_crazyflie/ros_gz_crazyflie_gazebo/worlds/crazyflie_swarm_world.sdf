<?xml version="1.0" ?>

<sdf version="1.8">
  <world name="swarm_demo">
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== CF1 ==================== -->
    <model name="cf1">
      <pose>-0.5 -0.5 0.05 0 0 0</pose>
      <link name="cf1/body">
        <pose>0 0 17.425E-3 0 0 0</pose>
        <inertial>
          <mass>0.025</mass>
          <inertia>
            <ixx>16.571710E-06</ixx><iyy>16.655602E-06</iyy><izz>29.261652E-06</izz>
            <ixy>0.830806E-06</ixy><ixz>0.718277E-06</ixz><iyz>1.800197E-06</iyz>
          </inertia>
        </inertial>
        <collision name="cf1/body_collision">
          <geometry><box><size>0.10 0.10 34.850E-3</size></box></geometry>
        </collision>
        <visual name="cf1/body_visual">
          <geometry><mesh><uri>model://crazyflie/meshes/cf2_assembly.dae</uri></mesh></geometry>
        </visual>
      </link>
      <link name="cf1/m1_prop">
        <pose>0.031 -0.031 0.021 0 0 0</pose>
        <inertial><mass>0.0008</mass><inertia><ixx>8.33333E-09</ixx><iyy>1.08333E-07</iyy><izz>1.13333E-07</izz></inertia></inertial>
        <visual name="cf1/m1_visual"><geometry><mesh><uri>model://crazyflie/meshes/ccw_prop.dae</uri></mesh></geometry></visual>
      </link>
      <link name="cf1/m2_prop">
        <pose>-0.031 -0.031 0.021 0 0 0</pose>
        <inertial><mass>0.0008</mass><inertia><ixx>8.33333E-09</ixx><iyy>1.08333E-07</iyy><izz>1.13333E-07</izz></inertia></inertial>
        <visual name="cf1/m2_visual"><geometry><mesh><uri>model://crazyflie/meshes/cw_prop.dae</uri></mesh></geometry></visual>
      </link>
      <link name="cf1/m3_prop">
        <pose>-0.031 0.031 0.021 0 0 0</pose>
        <inertial><mass>0.0008</mass><inertia><ixx>8.33333E-09</ixx><iyy>1.08333E-07</iyy><izz>1.13333E-07</izz></inertia></inertial>
        <visual name="cf1/m3_visual"><geometry><mesh><uri>model://crazyflie/meshes/ccw_prop.dae</uri></mesh></geometry></visual>
      </link>
      <link name="cf1/m4_prop">
        <pose>0.031 0.031 0.021 0 0 0</pose>
        <inertial><mass>0.0008</mass><inertia><ixx>8.33333E-09</ixx><iyy>1.08333E-07</iyy><izz>1.13333E-07</izz></inertia></inertial>
        <visual name="cf1/m4_visual"><geometry><mesh><uri>model://crazyflie/meshes/cw_prop.dae</uri></mesh></geometry></visual>
      </link>
      <joint name="cf1/m1_joint" type="revolute"><child>cf1/m1_prop</child><parent>cf1/body</parent><axis><xyz>0 0 1</xyz></axis></joint>
      <joint name="cf1/m2_joint" type="revolute"><child>cf1/m2_prop</child><parent>cf1/body</parent><axis><xyz>0 0 1</xyz></axis></joint>
      <joint name="cf1/m3_joint" type="revolute"><child>cf1/m3_prop</child><parent>cf1/body</parent><axis><xyz>0 0 1</xyz></axis></joint>
      <joint name="cf1/m4_joint" type="revolute"><child>cf1/m4_prop</child><parent>cf1/body</parent><axis><xyz>0 0 1</xyz></axis></joint>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
        <robotNamespace>cf1</robotNamespace><jointName>cf1/m1_joint</jointName><linkName>cf1/m1_prop</linkName>
        <turningDirection>ccw</turningDirection><maxRotVelocity>2618</maxRotVelocity>
        <motorConstant>1.28192e-08</motorConstant><momentConstant>0.005964552</momentConstant>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient><rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim><actuator_number>0</actuator_number><motorType>velocity</motorType>
      </plugin>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
        <robotNamespace>cf1</robotNamespace><jointName>cf1/m2_joint</jointName><linkName>cf1/m2_prop</linkName>
        <turningDirection>cw</turningDirection><maxRotVelocity>2618</maxRotVelocity>
        <motorConstant>1.28192e-08</motorConstant><momentConstant>0.005964552</momentConstant>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient><rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim><actuator_number>1</actuator_number><motorType>velocity</motorType>
      </plugin>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
        <robotNamespace>cf1</robotNamespace><jointName>cf1/m3_joint</jointName><linkName>cf1/m3_prop</linkName>
        <turningDirection>ccw</turningDirection><maxRotVelocity>2618</maxRotVelocity>
        <motorConstant>1.28192e-08</motorConstant><momentConstant>0.005964552</momentConstant>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient><rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim><actuator_number>2</actuator_number><motorType>velocity</motorType>
      </plugin>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
        <robotNamespace>cf1</robotNamespace><jointName>cf1/m4_joint</jointName><linkName>cf1/m4_prop</linkName>
        <turningDirection>cw</turningDirection><maxRotVelocity>2618</maxRotVelocity>
        <motorConstant>1.28192e-08</motorConstant><momentConstant>0.005964552</momentConstant>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient><rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim><actuator_number>3</actuator_number><motorType>velocity</motorType>
      </plugin>
      <plugin filename="gz-sim-multicopter-control-system" name="gz::sim::systems::MulticopterVelocityControl">
        <robotNamespace>cf1</robotNamespace>
        <commandSubTopic>gazebo/command/twist</commandSubTopic>
        
        <comLinkName>cf1/body</comLinkName>
        <velocityGain>1.25 1.25 0.2425</velocityGain>
        <attitudeGain>0.02 0.02 0.02</attitudeGain>
        <angularRateGain>0.005 0.005 0.005</angularRateGain>
        <rotorConfiguration>
          <rotor><jointName>cf1/m1_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>1</direction></rotor>
          <rotor><jointName>cf1/m2_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>-1</direction></rotor>
          <rotor><jointName>cf1/m3_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>1</direction></rotor>
          <rotor><jointName>cf1/m4_joint</jointName><forceConstant>1.28192e-08</forceConstant><momentConstant>0.005964552</momentConstant><direction>-1</direction></rotor>
        </rotorConfiguration>
      </plugin>
      <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
        <dimensions>3</dimensions>
      </plugin>
    </model>

